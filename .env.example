# =============================================================
# VARIÁVEIS DE AMBIENTE — GoTaxi SaaS
# Renomeie este arquivo para .env e preencha os valores
# =============================================================

# ─────────────────────────────────────────
# BANCO DE DADOS (obrigatório)
# ─────────────────────────────────────────
DATABASE_URL=postgres://usuario:senha@host:5432/gotaxi

# ─────────────────────────────────────────
# SEGURANÇA (obrigatório)
# ─────────────────────────────────────────
# Gere em: https://generate-secret.vercel.app/64
JWT_SECRET=cole_uma_string_aleatoria_de_64_chars_aqui

# ─────────────────────────────────────────
# DOMÍNIO PÚBLICO (obrigatório em produção)
# Exemplo: https://gotaxi.com.br
# ─────────────────────────────────────────
PUBLIC_DOMAIN=https://gotaxi.com.br

# ─────────────────────────────────────────
# GOOGLE MAPS (obrigatório para mapas e rotas)
# Obtenha em: https://console.cloud.google.com/google/maps-apis/credentials
# ─────────────────────────────────────────
# Chave para uso no FRONTEND (browser/mobile) — restrinja por HTTP referrer
GOOGLE_MAPS_KEY=AIzaSy...

# Chave para uso no BACKEND (server-side) — restrinja por IP
GOOGLE_MAPS_SERVER_KEY=AIzaSy...

# ─────────────────────────────────────────
# GOOGLE CLOUD STORAGE (opcional — para upload de imagens)
# Se não configurado, imagens serão salvas localmente em /uploads
# ─────────────────────────────────────────
# Nome do bucket no Google Cloud Storage
DEFAULT_OBJECT_STORAGE_BUCKET_ID=

# Caminhos públicos de busca de objetos (separados por vírgula)
PUBLIC_OBJECT_SEARCH_PATHS=

# Diretório para objetos privados
PRIVATE_OBJECT_DIR=

# ─────────────────────────────────────────
# FIREBASE (opcional — para push notifications de motoristas)
# Obtenha em: https://console.firebase.google.com → Configurações do Projeto → Cloud Messaging
# ─────────────────────────────────────────
FIREBASE_SERVER_KEY=

# ─────────────────────────────────────────
# OPENAI (opcional — para suporte com IA)
# Obtenha em: https://platform.openai.com/api-keys
# ─────────────────────────────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=sk-proj-...

# ─────────────────────────────────────────
# MOBILE (Expo) — somente para build/dev do app
# ─────────────────────────────────────────
# Domínio da API sem https:// (ex: gotaxi.com.br ou localhost:8080)
EXPO_PUBLIC_DOMAIN=gotaxi.com.br

# Chave Google Maps para o app mobile
EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIzaSy...

# ─────────────────────────────────────────
# SERVIDOR (configurado automaticamente — não precisa pedir ao cliente)
# ─────────────────────────────────────────
NODE_ENV=production
PORT=8080
